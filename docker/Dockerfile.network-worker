FROM python:3.11-slim

ENV OMP_NUM_THREADS=1 \
    OPENBLAS_NUM_THREADS=1 \
    MKL_NUM_THREADS=1 \
    NUMEXPR_NUM_THREADS=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DEFAULT_TIMEOUT=120 \
    PIP_RETRIES=10

WORKDIR /app
RUN pip install --no-cache-dir --prefer-binary numpy scipy pandas
COPY src /app/src

ENTRYPOINT ["python", "-m", "src.coded_learning_exp.network_runtime", "worker"]
